APP_ENV=development
APP_SECRET_KEY=change-me
APP_USERNAME=plantbuddy
APP_PASSWORD=change-me
JWT_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30
DOCS_ENABLED=true
SECURE_HEADERS_ENABLED=true
RUN_MIGRATIONS_ON_STARTUP=false
FORWARDED_ALLOW_IPS=*

DATABASE_URL=postgresql+psycopg://plantbuddy:plantbuddy@postgres:5432/plantbuddy
DATABASE_SCHEMA=plantbuddy

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEP_ANALYSIS_MODEL=gpt-5.2-chat-latest
BACKGROUND_WORKER_ENABLED=true
BACKGROUND_WORKER_INTERVAL_SECONDS=15
PLANTBUDDY_STORAGE_PATH=/data/plantbuddy
MAX_UPLOAD_MB=25
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000,https://plantbuddy.a42.casa
PUBLIC_BASE_URL=https://plantbuddy.a42.casa
FRONTEND_API_BASE_URL=http://127.0.0.1:8000/api
TRUSTED_HOSTS=localhost,127.0.0.1,plantbuddy.a42.casa
